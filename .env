# =========================================================================
# CONFIGURATION FILE FOR REAL EMAIL OTP DELIVERY (XAU/USD GOLD TERMINAL)
# =========================================================================
# Copy this file to '.env' at the root of the project.
# Deno 2.x automatically loads this file at startup!
# =========================================================================

# -------------------------------------------------------------------------
# OPTION A: SMTP (Highly Recommended - Zero domain verification required!)
# Use any standard email provider, e.g., Gmail, Yahoo, Brevo SMTP.
# -------------------------------------------------------------------------
# Hostname of your SMTP provider (e.g., smtp.gmail.com, smtp-relay.brevo.com)
SMTP_HOST=

# SMTP port (587 for TLS, 465 for SSL, or 25/2525)
SMTP_PORT=587

# Your SMTP login username (usually your email address)
SMTP_USER=

# Your SMTP login password (For Gmail, you MUST use a "Google App Password")
SMTP_PASSWORD=

# Sender email address displayed in the recipient's inbox
SMTP_FROM="XAU/USD Gold Terminal <no-reply@goldterminal.pro>"

